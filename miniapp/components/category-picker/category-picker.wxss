.picker-shell { display: flex; align-items: center; justify-content: space-between; padding: 20rpx; background: rgba(255,255,255,0.8); border-radius: 12rpx; }
.label { font-size: 28rpx; color: #1D1D1F; }
.arrow { color: #86868B; font-size: 24rpx; }
.overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); z-index: 100; }
.dropdown { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 30rpx 30rpx 0 0; z-index: 101; padding: 20rpx; max-height: 50vh; overflow-y: auto; }
.item { padding: 28rpx 20rpx; border-bottom: 1rpx solid rgba(0,0,0,0.05); font-size: 30rpx; }
.item:last-child { border-bottom: none; }

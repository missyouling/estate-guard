.container { padding: 20rpx 30rpx 40rpx; }
.user-card { display: flex; align-items: center; gap: 24rpx; padding: 30rpx; border-radius: 20rpx; margin-bottom: 20rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: #007AFF; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 44rpx; font-weight: 700; flex-shrink: 0; }
.user-info { flex: 1; }
.uname { font-size: 34rpx; font-weight: 700; display: block; }
.urole { font-size: 24rpx; color: #007AFF; display: block; margin-top: 2rpx; }
.uphone { font-size: 24rpx; color: #86868B; display: block; margin-top: 2rpx; }
.uroom { font-size: 24rpx; color: #86868B; display: block; }

.stats-card { display: flex; padding: 30rpx; border-radius: 20rpx; margin-bottom: 20rpx; }
.stat { flex: 1; text-align: center; }
.stat-num { font-size: 44rpx; font-weight: 700; color: #007AFF; display: block; }
.stat-lbl { font-size: 22rpx; color: #86868B; margin-top: 4rpx; display: block; }

.section { background: rgba(255,255,255,0.8); border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; display: block; }
.input { padding: 20rpx; background: #fff; border-radius: 12rpx; margin-bottom: 12rpx; font-size: 28rpx; border: 1rpx solid rgba(0,0,0,0.08); }
.btn { background: #007AFF; color: #fff; border-radius: 12rpx; font-size: 28rpx; font-weight: 500; }
.btn::after { border: none; }

.logout-btn { background: #FFF1F0; color: #FF3B30; border-radius: 14rpx; font-size: 28rpx; font-weight: 500; margin-top: 20rpx; }
.logout-btn::after { border: none; }

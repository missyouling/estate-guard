.container { padding-bottom: 40rpx; }
.loading { text-align: center; padding: 200rpx 0; color: #86868B; }
.media-area { background: #000; }
.media-image { width: 100%; }
.media-video { width: 100%; }
.media-audio { width: 100%; padding: 40rpx; box-sizing: border-box; }

.info-card { margin: 20rpx; padding: 30rpx; border-radius: 20rpx; }
.info-title { font-size: 32rpx; font-weight: 700; margin-bottom: 20rpx; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.05); font-size: 26rpx; }
.lbl { color: #86868B; }

.actions { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 0 20rpx; }
.act-btn { flex: 1; min-width: 120rpx; font-size: 24rpx; padding: 16rpx; border-radius: 12rpx; background: rgba(0,0,0,0.04); color: #1D1D1F; }
.act-btn::after { border: none; }
.act-btn.primary { background: #007AFF; color: #fff; }
.act-btn.danger { background: #FFF1F0; color: #FF3B30; }
